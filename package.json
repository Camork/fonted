{
	"name": "fonted-plus",
	"displayName": "Fonted Plus",
	"description": "Change UI font for vscode. Just that.",
	"version": "2.0.1",
	"publisher": "camork",
	"icon": "assets/fonted.png",
	"repository": "https://github.com/camork/fonted.git",
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:fonted.helloWorld",
		"onStartupFinished"
	],
	"extensionKind": [
		"ui"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "fonted.enable",
				"title": "Fonted: Enable"
			},
			{
				"command": "fonted.disable",
				"title": "Fonted: Disable"
			}
		],
		"configuration": {
			"type": "object",
			"title": "Fonted",
			"properties": {
				"fonted.font": {
					"type": "string",
					"description": "Font to replace UI font"
				},
				"fonted.fontStretch": {
					"type": "string",
					"description": "font-stretch value"
				},
                "fonted.autoFix": {
                    "type": "boolean",
                    "description": "Fix checksums automatically when VSCode start up",
                    "default": false
                }
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "pnpm run compile",
		"compile": "node ./bundle.mjs",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm run compile && pnpm run lint",
		"test": "node ./out/test/runTest.js",
		"package": "npx @vscode/vsce package --no-dependencies"
	},
	"devDependencies": {
		"@types/glob": "^9.0.0",
		"@types/jsdom": "^28.0.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.5.0",
		"@types/vscode": "^1.95.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.27.4",
		"eslint": "^10.1.0",
		"glob": "^13.0.6",
		"mocha": "^11.7.5",
		"typescript": "^5.9.3"
	},
	"dependencies": {
        "sudo-prompt": "^9.2.1",
        "tmp": "^0.2.3"
	}
}
